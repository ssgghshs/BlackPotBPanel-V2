#!/bin/bash

# BlackPotBPanel 面板管理入口 / Panel Management Entry
# ========================================
# 部署到 /usr/local/bin 后可直接在终端输入 bpctl 调用
# Deploy to /usr/local/bin for system-wide access:
# ln -sf /opt/blackpotbpanel-v2/cli/bpctl /usr/local/bin/bpctl

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

detect_language() {
    local lang
    lang=$(echo "${LANG:-}" | tr '[:upper:]' '[:lower:]')
    case "$lang" in
        zh_cn*|zh_cn*|zh*)
            echo "zh"
            ;;
        *)
            echo "en"
            ;;
    esac
}

select_language() {
    clear
    echo -e "${CYAN}"
    echo "================================================================"
    echo "=           BlackPotBPanel Panel Management Tool v2.0          ="
    echo "=      __    __           __               __  __              ="
    echo "=     / /_  / /___ ______/ /______  ____  / /_/ /_  ____       ="
    echo "=    / __ \/ / __ \`/ ___/ //_/ __ \/ __ \/ __/ __ \/ __ \\    ="
    echo "=   / /_/ / / /_/ / /__/ ,< / /_/ / /_/ / /_/ /_/ / /_/ /      ="
    echo "=  /_.___/_/\__,_/\___/_/|_/ .___/\____/\__/_.___/ .___/       ="
    echo "=                         /_/                   /_/            ="
    echo "================================================================"
    echo -e "${NC}"
    echo ""
    echo "   1.Chinese"
    echo "   2.English"
    echo ""
    read -p "Please select language / 请选择语言（Chinese/English） [1/2]: " lang_choice
    case "$lang_choice" in
        1|zh|cn)
            return 0
            ;;
        2|en)
            return 1
            ;;
        *)
            echo -e "${YELLOW}Invalid choice, defaulting to English${NC}"
            sleep 1
            return 1
            ;;
    esac
}

main() {
    if [ "$(id -u)" -ne 0 ]; then
        echo -e "${RED}[Error / 错误] Please run as root / 请使用 root 用户运行${NC}"
        exit 1
    fi

    local lang
    if [ "$1" = "zh" ] || [ "$1" = "en" ]; then
        lang="$1"
    else
        lang=$(detect_language)
        if [ "$lang" != "zh" ]; then
            lang="en"
        fi
        if [ -z "$1" ]; then
            if select_language; then
                lang="zh"
            else
                lang="en"
            fi
        fi
    fi

    if [ "$lang" = "zh" ]; then
        if [ -f "$SCRIPT_DIR/bpctl_zh.sh" ]; then
            exec bash "$SCRIPT_DIR/bpctl_zh.sh"
        else
            echo -e "${RED}[错误] 未找到 bpctl_zh.sh${NC}"
            exit 1
        fi
    else
        if [ -f "$SCRIPT_DIR/bpctl_en.sh" ]; then
            exec bash "$SCRIPT_DIR/bpctl_en.sh"
        else
            echo -e "${RED}[Error] bpctl_en.sh not found${NC}"
            exit 1
        fi
    fi
}

main "$@"
